FROM node:24 AS build-stage

ARG SERVER_IP
ARG API_PORT
ARG CLIENT_PORT

WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .


RUN echo "Construyendo frontend con URLs relativas (API via nginx proxy)"

RUN sed -i "s|baseURL: '.*'|baseURL: '/api/apiRequest/'|g" src/environments/environment.ts src/environments/environment.development.ts \
    && sed -i "s|socketURL: '.*'|socketURL: '/'|g" src/environments/environment.ts src/environments/environment.development.ts \
    && sed -i "s|host: '.*'|host: '/'|g" src/environments/environment.ts src/environments/environment.development.ts

RUN npm run build -- --configuration production

FROM nginx:stable-alpine

RUN rm /etc/nginx/conf.d/default.conf \
    && rm -f /usr/share/nginx/html/index.html

COPY --from=build-stage /app/dist/vertex20/browser /usr/share/nginx/html

COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]